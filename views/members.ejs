        <h5 class="card-title mb-0">Member 1</h5>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100">
      <img
        class="card-img-top"
        src="/2.png"
        alt="Member 2"
      />
      <div class="card-body">
        <h5 class="card-title mb-0">Member 2</h5>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100">
      <img
        class="card-img-top"
        src="/3.png"
        alt="Member 3"
      />
      <div class="card-body">
        <h5 class="card-title mb-0">Member 3</h5>
      </div>
    </div>
  </div>
</div>

<%- include("templates/footer") %>
