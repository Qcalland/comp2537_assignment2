<%- include("templates/header", { title: "Admin" }) %>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
  <div>
    <h1 class="mb-1">Admin</h1>
    <div class="text-muted">Hello, <strong><%= name %></strong>.</div>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a class="btn btn-outline-secondary" href="/members">Members</a>
    <a class="btn btn-outline-secondary" href="/logout">Logout</a>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-striped align-middle">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>User type</th>
        <th class="text-end">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% for (const user of users) { %>
        <%- include("templates/user", { user }) %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("templates/footer") %>
